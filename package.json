{
  "name": "nowinweb-new",
  "version": "1.0.0",
  "private": true,
  "description": "Compatibility build pipeline for NOW IN WEB",
  "scripts": {
    "build:css": "sass scss/main.scss css/main.min.css --style=expanded --source-map && postcss css/main.min.css --replace --map",
    "build:js": "babel js --out-dir js-compat --extensions \".js\" --source-maps",
    "build": "npm run build:css && npm run build:js"
  },
  "browserslist": {
    "production": [
      "chrome >= 80",
      "edge >= 80",
      "firefox >= 78",
      "safari >= 12",
      "ios_saf >= 12",
      "not ie <= 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/cli": "latest",
    "@babel/core": "latest",
    "@babel/preset-env": "latest",
    "autoprefixer": "latest",
    "cssnano": "latest",
    "postcss": "latest",
    "postcss-cli": "latest",
    "sass": "latest"
  }
}
